# ── App ───────────────────────────────────────────────────────────────────────

NODE_ENV=development

# Your app's public URL — used as the JWT issuer claim (iss)
APP_URL=http://localhost:3000

# iron-session encryption key — must be at least 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-secret-min-32-chars

# ── Admin Dashboard ───────────────────────────────────────────────────────────

# Secret to log into the /dashboard
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_SECRET=change-this-admin-secret

# ── Plugin Communication ──────────────────────────────────────────────────────

# Shared secret between this app and the WordPress plugin
# Must match the Plugin Secret field in WP Settings → Cad Dev SSO
PLUGIN_SECRET=change-this-plugin-secret

# ── Auth Code (OTP) ───────────────────────────────────────────────────────────

# Signs OTP session tokens — must differ from SESSION_SECRET
OTP_SECRET=change-this-otp-secret-different-from-session

# Default email that receives OTP login codes (can be changed via Dashboard → Settings)
NOTIFICATION_EMAIL=admin@yourcompany.com

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI to register:
#   Development : http://localhost:3000/auth/google/callback
#   Production  : https://your-app.vercel.app/auth/google/callback

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── SMTP (for OTP emails) ─────────────────────────────────────────────────────
# Gmail: use an App Password — https://myaccount.google.com/apppasswords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Cad Dev SSO <your-email@gmail.com>"

# ── Allowed WordPress Origins ─────────────────────────────────────────────────
# Exact origins of your WordPress sites — comma-separated, no trailing slash

ALLOWED_REDIRECT_ORIGINS=http://localhost,http://localhost:8080
